# OnchainKit API Key
NEXT_PUBLIC_ONCHAINKIT_API_KEY=your_onchainkit_api_key

# Base Account Configuration
# No additional configuration needed for Base Account
# The application uses Base Account SDK for authentication

# Base Paymaster Configuration
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_PAYMASTER_URL=https://api.developer.coinbase.com/rpc/v1/base/
NEXT_PUBLIC_BASE_BUNDLER_URL=https://api.developer.coinbase.com/rpc/v1/base/
NEXT_PUBLIC_CDP_API_KEY=your_cdp_api_key_here

# Pinata IPFS Configuration
NEXT_PUBLIC_PINATA_API_KEY=your_pinata_api_key_here
NEXT_PUBLIC_PINATA_SECRET_API_KEY=your_pinata_secret_api_key_here

# Blockchain Configuration
NEXT_PUBLIC_INCIDENT_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# Base Pay Configuration
NEXT_PUBLIC_BASE_PAY_RECIPIENT_ADDRESS=0x742d35Cc6634C0532925a3b8D4C9db96C4b5Da5e

# Base Sepolia Configuration
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_USDC_CONTRACT_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Project Configuration
NEXT_PUBLIC_PROJECT_NAME=Baxela
NEXT_PUBLIC_PLATFORM_URL=https://baxela.vercel.app

# Department Email Notifications (via Resend — https://resend.com)
# Get a free API key at resend.com, then verify your sending domain
RESEND_API_KEY=re_your_api_key_here
NOTIFICATION_FROM_EMAIL=reports@yourdomain.com

# Department recipient overrides (defaults are the real SA government addresses)
# Uncomment and set these to route to specific regional offices instead
# DEPT_EMAIL_POLICE=complaints@ipid.gov.za
# DEPT_EMAIL_SOCIAL_SERVICES=info@dsd.gov.za
# DEPT_EMAIL_BUILDING=info@nhbrc.org.za
# DEPT_EMAIL_SERVICE_DELIVERY=info@cogta.gov.za
# DEPT_EMAIL_ELECTION=complaints@elections.org.za